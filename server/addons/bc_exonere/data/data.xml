<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="fiscal_position_tunisie_exoneree" model="account.fiscal.position">
            <field name="name">Exonérée (Tunisie)</field>
            <field name="note">Exonération de TVA selon certificat de suspension.</field>
            <field name="auto_apply" eval="False"/>
            <field name="country_id" ref="base.tn"/>
        </record>

    </data>
    <data noupdate="1">
        <record id="ir_cron_check_partner_exoneration" model="ir.cron">
            <field name="name">Partenaires : Vérification expiration exonération TVA</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_exoneration_expiry()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(datetime.now() + relativedelta(days=1)).strftime('%Y-%m-%d 01:00:00')"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>