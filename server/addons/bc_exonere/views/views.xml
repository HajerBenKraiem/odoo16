<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_fiscal_exo" model="ir.ui.view">
        <field name="name">res.par;tner.form.inherit.fiscal.exo</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="num_exoneration"/>
                <field name="date_debut_exoneration"/>
                <field name="date_fin_exoneration"/>
            </xpath>
        </field>
    </record>
    <record id="view_move_form_inherit_fiscal" model="ir.ui.view">
        <field name="name">account.move.form.inherit.fiscal</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="num_exoneration"
                       attrs="{'invisible': [('move_type', 'not in', ('out_invoice', 'out_refund'))]}"
                       placeholder="N° Exonération Client" readonly="0"/>

                <field name="date_debut_exoneration"
                       attrs="{'invisible': [('move_type', 'not in', ('out_invoice', 'out_refund'))]}"
                       readonly="0"/>

                <field name="date_fin_exoneration"
                       attrs="{'invisible': [('move_type', 'not in', ('out_invoice', 'out_refund'))]}"
                       readonly="0"/>
            </xpath>
        </field>
    </record>
    <record id="action_invoice_custom" model="ir.actions.server">
        <field name="name">Génération BC exonéré</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.export_exonerated_invoice()
        </field>
</record>
  <record id="view_move_form_inherit_export" model="ir.ui.view">
    <field name="name">account.move.export.button</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">

        <xpath expr="//header" position="inside">
            <button name="export_exonerated_invoice"
                    type="object"
                    string="Exporter Exonération"
                    class="btn-primary"/>
        </xpath>

    </field>
</record>
</odoo>

